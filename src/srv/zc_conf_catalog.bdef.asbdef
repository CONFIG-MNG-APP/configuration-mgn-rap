projection;
strict ( 2 );
use draft;

define behavior for ZC_CONF_CATALOG alias Catalog
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _FieldDef { create; }
}

define behavior for ZC_CONF_FIELD_DEF alias FieldDef
{
  use update;
  use delete;

  use association _Catalog;
}