  expose ZC_VH_CUST_GROUP as CustGroupDef;
  expose ZC_VH_CURRENCY as CurrencyDef;
  expose ZC_VH_MATL_GRP as MatlGrpDef;
  expose ZC_VH_INSPECTOR as InspectorDef;
}