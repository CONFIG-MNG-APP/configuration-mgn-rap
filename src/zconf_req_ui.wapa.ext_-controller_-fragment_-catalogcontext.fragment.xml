<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
    <VBox                                                                                                                                                                                                                                                      
        visible="{catalogDisplay>/hasCatalogContext}"                                                                                                                                                                                                          
        class="sapUiSmallMargin">                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
        <HBox wrap="Wrap" class="sapUiTinyMarginTop">                                                                                                                                                                                                          
            <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">                                                                                                                                                                            
                <Label text="Configuration" />                                                                                                                                                                                                                 
                <Text text="{catalogDisplay>/ConfName}" />                                                                                                                                                                                                     
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="10rem">                                                                                                                                                                            
                <Label text="Module" />                                                                                                                                                                                                                        
                <Text text="{catalogDisplay>/ModuleId}" />                                                                                                                                                                                                     
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="16rem">                                                                                                                                                                            
                <Label text="Target CDS" />                                                                                                                                                                                                                    
                <Text text="{catalogDisplay>/TargetCds}" />                                                                                                                                                                                                    
            </VBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <VBox class="sapUiSmallMarginBottom" width="10rem">                                                                                                                                                                                                
                <Label text="Environment" />                                                                                                                                                                                                                   
                <Text text="{catalogDisplay>/EnvId}" />                                                                                                                                                                                                        
            </VBox>                                                                                                                                                                                                                                            
        </HBox>                                                                                                                                                                                                                                                
    </VBox>                                                                                                                                                                                                                                                    
</core:FragmentDefinition>                                                                                                                                                                                                                                     