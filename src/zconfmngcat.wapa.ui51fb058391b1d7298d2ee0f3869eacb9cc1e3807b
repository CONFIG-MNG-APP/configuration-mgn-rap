sap.ui.define([], function () {                                                                                                                                                                                                                                
  "use strict";                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
  return {                                                                                                                                                                                                                                                     
    onMaintainPress: function () {                                                                                                                                                                                                                             
      try {                                                                                                                                                                                                                                                    
        let oBindingContext = null;                                                                                                                                                                                                                            
        const arg0 = arguments[0];                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        if (arg0 && typeof arg0.getObject === "function") {                                                                                                                                                                                                    
          oBindingContext = arg0;                                                                                                                                                                                                                              
        } else if (                                                                                                                                                                                                                                            
          Array.isArray(arg0) &&                                                                                                                                                                                                                               
          arg0[0] &&                                                                                                                                                                                                                                           
          typeof arg0[0].getObject === "function"                                                                                                                                                                                                              
        ) {                                                                                                                                                                                                                                                    
          oBindingContext = arg0[0];                                                                                                                                                                                                                           
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        if (!oBindingContext) {                                                                                                                                                                                                                                
          console.error("No binding context found");                                                                                                                                                                                                           
          return;                                                                                                                                                                                                                                              
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        const oData = oBindingContext.getObject();                                                                                                                                                                                                             
        console.log("Current object =", oData);                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        const sBaseUrl = "http://localhost:8083/test/flp.html";                                                                                                                                                                                                
        const sQuery =                                                                                                                                                                                                                                         
          "?sap-ui-xx-viewCache=false" +                                                                                                                                                                                                                       
          "&mode=create" +                                                                                                                                                                                                                                     
          "&ConfId=" +                                                                                                                                                                                                                                         
          encodeURIComponent(oData.ConfId || "") +                                                                                                                                                                                                             
          "&ConfName=" +                                                                                                                                                                                                                                       
          encodeURIComponent(oData.ConfName || "") +                                                                                                                                                                                                           
          "&ModuleId=" +                                                                                                                                                                                                                                       
          encodeURIComponent(oData.ModuleId || "");                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
        const sHash = "#app-preview";                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
        const sUrl = sBaseUrl + sQuery + sHash;                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        console.log("Navigate URL =", sUrl);                                                                                                                                                                                                                   
        window.location.href = sUrl;                                                                                                                                                                                                                           
      } catch (e) {                                                                                                                                                                                                                                            
        console.error("onMaintainPress error:", e);                                                                                                                                                                                                            
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
  };                                                                                                                                                                                                                                                           
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               