<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:f="sap.ui.layout.form"                                                                                                                                                                                                                               
    xmlns:l="sap.ui.layout">                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
    <Dialog id="detailDialog"                                                                                                                                                                                                                                  
            title="{= ${detail>/confName} &amp;&amp; ${detail>/confName} !== '-' ? ${detail>/confName} : 'Configuration Detail'}"                                                                                                                              
            contentWidth="72rem" contentHeight="auto"                                                                                                                                                                                                          
            verticalScrolling="true" draggable="true" resizable="true">                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                <!-- ── Request Info ──────────────────────────────────────── -->                                                                                                                                                                              
                <Panel headerText="Thông tin Request" expandable="false" class="sapUiTinyMarginBottom">                                                                                                                                                        
                    <HBox wrap="Wrap" class="sapUiSmallMargin" alignItems="Start">                                                                                                                                                                             
                        <VBox class="sapUiMediumMarginEnd" width="6rem">                                                                                                                                                                                       
                            <Label text="Module" design="Bold"/>                                                                                                                                                                                               
                            <ObjectStatus                                                                                                                                                                                                                      
                                text="{detail>/module}"                                                                                                                                                                                                        
                                state="{= ${detail>/module} === 'FI' ? 'Warning' :                                                                                                                                                                             
                                           ${detail>/module} === 'SD' ? 'Success' : 'Information'}"                                                                                                                                                            
                                inverted="true"/>                                                                                                                                                                                                              
                        </VBox>                                                                                                                                                                                                                                
                        <VBox class="sapUiMediumMarginEnd" width="10rem">                                                                                                                                                                                      
                            <Label text="Requested By" design="Bold"/>                                                                                                                                                                                         
                            <HBox alignItems="Center">                                                                                                                                                                                                         
                                <core:Icon src="sap-icon://employee" color="#89919A"                                                                                                                                                                           
                                           size="0.85rem" class="sapUiTinyMarginEnd"/>                                                                                                                                                                         
                                <Text text="{detail>/by}"/>                                                                                                                                                                                                    
                            </HBox>                                                                                                                                                                                                                            
                        </VBox>                                                                                                                                                                                                                                
                        <VBox class="sapUiMediumMarginEnd" width="8rem">                                                                                                                                                                                       
                            <Label text="ENV hiện tại" design="Bold"/>                                                                                                                                                                                         
                            <ObjectStatus                                                                                                                                                                                                                      
                                text="{detail>/curEnv}"                                                                                                                                                                                                        
                                state="{= ${detail>/curEnv} === 'PRD' ? 'Success' :                                                                                                                                                                            
                                           ${detail>/curEnv} === 'QAS' ? 'Warning' : 'Information'}"                                                                                                                                                           
                                inverted="true"/>                                                                                                                                                                                                              
                        </VBox>                                                                                                                                                                                                                                
                        <VBox class="sapUiMediumMarginEnd">                                                                                                                                                                                                    
                            <Label text="Reason" design="Bold"/>                                                                                                                                                                                               
                            <Text text="{= ${detail>/reason} &amp;&amp; ${detail>/reason} !== '-' ? ${detail>/reason} : '(không có)'}"                                                                                                                         
                                  wrapping="true" width="16rem"/>                                                                                                                                                                                              
                        </VBox>                                                                                                                                                                                                                                
                        <VBox>                                                                                                                                                                                                                                 
                            <Label text="REQ_ID" design="Bold"/>                                                                                                                                                                                               
                            <Text text="{detail>/reqId}" wrapping="false"                                                                                                                                                                                      
                                  class="sapUiSmallText sapThemeNeutralText"/>                                                                                                                                                                                 
                        </VBox>                                                                                                                                                                                                                                
                    </HBox>                                                                                                                                                                                                                                    
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                <!-- ── Promote Journey ────────────────────────────────────── -->                                                                                                                                                                             
                <Panel expandable="true" expanded="true" class="sapUiTinyMarginBottom">                                                                                                                                                                        
                    <headerToolbar>                                                                                                                                                                                                                            
                        <Toolbar style="Clear">                                                                                                                                                                                                                
                            <core:Icon src="sap-icon://journey-arrive" color="#0070F2"                                                                                                                                                                         
                                       size="1rem" class="sapUiTinyMarginEnd"/>                                                                                                                                                                                
                            <Title text="Promote Journey" level="H4"/>                                                                                                                                                                                         
                        </Toolbar>                                                                                                                                                                                                                             
                    </headerToolbar>                                                                                                                                                                                                                           
                    <!-- Journey được render bởi controller -->                                                                                                                                                                                                
                    <HBox id="journeyContainer" alignItems="Center" justifyContent="Center"                                                                                                                                                                    
                          class="sapUiSmallMargin"/>                                                                                                                                                                                                           
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                <!-- ── Rollback Confirm Panel — hiện khi user click ↩ Rollback trên node ── -->                                                                                                                                                               
                <Panel visible="{detail>/showRollbackConfirm}"                                                                                                                                                                                                 
                       class="sapUiTinyMarginBottom">                                                                                                                                                                                                          
                    <headerToolbar>                                                                                                                                                                                                                            
                        <Toolbar>                                                                                                                                                                                                                              
                            <core:Icon src="sap-icon://warning2" color="#E9730C"                                                                                                                                                                               
                                       size="1rem" class="sapUiTinyMarginEnd"/>                                                                                                                                                                                
                            <Title text="{= 'Xác nhận Rollback — ENV: ' + ${detail>/rollbackTargetEnv}}"                                                                                                                                                       
                                   level="H5"/>                                                                                                                                                                                                                
                            <ToolbarSpacer/>                                                                                                                                                                                                                   
                            <Button icon="sap-icon://decline" tooltip="Hủy"                                                                                                                                                                                    
                                    type="Transparent" press=".onRollbackCancel"/>                                                                                                                                                                             
                        </Toolbar>                                                                                                                                                                                                                             
                    </headerToolbar>                                                                                                                                                                                                                           
                    <VBox class="sapUiSmallMargin">                                                                                                                                                                                                            
                        <MessageStrip                                                                                                                                                                                                                          
                            text="{= 'ENV ' + ${detail>/rollbackTargetEnv} + ': toàn bộ dữ liệu sẽ revert về giá trị OldXxx. Hành động không thể hoàn tác!'}"                                                                                                  
                            type="Warning" showIcon="true"                                                                                                                                                                                                     
                            class="sapUiTinyMarginBottom"/>                                                                                                                                                                                                    
                        <Text text="(Tham khảo Preview bên dưới — cột Giá trị cũ là dữ liệu sau rollback)"                                                                                                                                                     
                              class="sapUiTinyMarginBottom"/>                                                                                                                                                                                                  
                        <HBox class="sapUiSmallMarginTop">                                                                                                                                                                                                     
                            <Button text="Xác nhận Rollback"                                                                                                                                                                                                   
                                    type="Reject"                                                                                                                                                                                                              
                                    icon="sap-icon://undo"                                                                                                                                                                                                     
                                    press=".onRollbackConfirm"/>                                                                                                                                                                                               
                            <Button text="Hủy"                                                                                                                                                                                                                 
                                    press=".onRollbackCancel"                                                                                                                                                                                                  
                                    class="sapUiSmallMarginBegin"/>                                                                                                                                                                                            
                        </HBox>                                                                                                                                                                                                                                
                    </VBox>                                                                                                                                                                                                                                    
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                <!-- ── Preview thay đổi ──────────────────────────────────── -->                                                                                                                                                                              
                <Panel expandable="true" expanded="true" class="sapUiTinyMarginBottom">                                                                                                                                                                        
                    <headerToolbar>                                                                                                                                                                                                                            
                        <Toolbar>                                                                                                                                                                                                                              
                            <Title text="Preview thay đổi" level="H4"/>                                                                                                                                                                                        
                            <ToolbarSpacer/>                                                                                                                                                                                                                   
                            <ToggleButton                                                                                                                                                                                                                      
                                text="Chỉ hiện thay đổi"                                                                                                                                                                                                       
                                icon="sap-icon://filter"                                                                                                                                                                                                       
                                pressed="{detail>/showChangedOnly}"                                                                                                                                                                                            
                                press=".onToggleChangedOnly"/>                                                                                                                                                                                                 
                        </Toolbar>                                                                                                                                                                                                                             
                    </headerToolbar>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                    <!-- Bảng dynamic — columns được build bởi controller qua _buildPreviewTable() -->                                                                                                                                                         
                    <VBox id="previewTableContainer"/>                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <buttons>                                                                                                                                                                                                                                              
            <Button id="dlgPromoteBtn"                                                                                                                                                                                                                         
                    text="{= 'Promote → ' + ${detail>/nextEnv}}"                                                                                                                                                                                               
                    icon="sap-icon://journey-arrive"                                                                                                                                                                                                           
                    type="Accept"                                                                                                                                                                                                                              
                    visible="{detail>/isPromoteMode}"                                                                                                                                                                                                          
                    enabled="{detail>/promoteEnabled}"                                                                                                                                                                                                         
                    press=".onDialogPromote"/>                                                                                                                                                                                                                 
            <Button text="Close"                                                                                                                                                                                                                               
                    press=".onDialogClose"/>                                                                                                                                                                                                                   
        </buttons>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
    </Dialog>                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               