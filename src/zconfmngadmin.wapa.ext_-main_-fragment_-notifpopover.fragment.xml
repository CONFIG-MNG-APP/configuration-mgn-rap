<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
    <Popover id="notifPopover"                                                                                                                                                                                                                                 
             title="Thông báo mới"                                                                                                                                                                                                                             
             placement="Bottom"                                                                                                                                                                                                                                
             contentWidth="28rem"                                                                                                                                                                                                                              
             showHeader="true">                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <List id="notifList"                                                                                                                                                                                                                               
                  items="{notif>/items}"                                                                                                                                                                                                                       
                  noDataText="Không có thông báo mới."                                                                                                                                                                                                         
                  showSeparators="Inner">                                                                                                                                                                                                                      
                <items>                                                                                                                                                                                                                                        
                    <CustomListItem>                                                                                                                                                                                                                           
                        <HBox alignItems="Center" justifyContent="SpaceBetween"                                                                                                                                                                                
                              class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiTinyMarginTopBottom">                                                                                                                                                      
                                                                                                                                                                                                                                                               
                            <!-- Nội dung thông báo -->                                                                                                                                                                                                        
                            <VBox class="sapUiSmallMarginEnd" width="18rem">                                                                                                                                                                                   
                                <Text text="{notif>title}"                                                                                                                                                                                                     
                                      class="sapUiBoldText" wrapping="true"/>                                                                                                                                                                                  
                                <Text text="{notif>description}"                                                                                                                                                                                               
                                      class="sapUiTinyMarginTop"/>                                                                                                                                                                                             
                                <HBox alignItems="Center" class="sapUiTinyMarginTop">                                                                                                                                                                          
                                    <core:Icon src="sap-icon://employee"                                                                                                                                                                                       
                                               color="#89919A" size="0.8rem"                                                                                                                                                                                   
                                               class="sapUiTinyMarginEnd"/>                                                                                                                                                                                    
                                    <Text text="{notif>by}" class="sapUiTinyMarginEnd"/>                                                                                                                                                                       
                                    <Text text="·" class="sapUiTinyMarginEnd"/>                                                                                                                                                                                
                                    <Text text="{notif>at}"/>                                                                                                                                                                                                  
                                </HBox>                                                                                                                                                                                                                        
                            </VBox>                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                            <!-- Button navigate thẳng vào module -->                                                                                                                                                                                          
                            <Button icon="sap-icon://arrow-right"                                                                                                                                                                                              
                                    tooltip="Chuyển đến module"                                                                                                                                                                                                
                                    type="Emphasized"                                                                                                                                                                                                          
                                    visible="{= !!${notif>moduleId}}"                                                                                                                                                                                          
                                    press=".onNotifGoToModule"/>                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                        </HBox>                                                                                                                                                                                                                                
                    </CustomListItem>                                                                                                                                                                                                                          
                </items>                                                                                                                                                                                                                                       
            </List>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <footer>                                                                                                                                                                                                                                               
            <Toolbar>                                                                                                                                                                                                                                          
                <ToolbarSpacer/>                                                                                                                                                                                                                               
                <Button text="Đánh dấu tất cả đã đọc"                                                                                                                                                                                                          
                        icon="sap-icon://accept"                                                                                                                                                                                                               
                        press=".onNotifMarkAllRead"                                                                                                                                                                                                            
                        visible="{= ${notif>/count} > 0}"/>                                                                                                                                                                                                    
            </Toolbar>                                                                                                                                                                                                                                         
        </footer>                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    </Popover>                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               