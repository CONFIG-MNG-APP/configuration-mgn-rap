<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
    <Dialog title="IT Admin — Environment Comparison"                                                                                                                                                                                                          
            contentWidth="72rem" contentHeight="42rem"                                                                                                                                                                                                         
            draggable="true" resizable="true">                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                <!-- Controls -->                                                                                                                                                                                                                              
                <HBox wrap="Wrap" alignItems="End" class="sapUiTinyMarginBottom">                                                                                                                                                                              
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Config"/>                                                                                                                                                                                                                 
                        <Select id="cmpModule" width="14rem">                                                                                                                                                                                                  
                            <items>                                                                                                                                                                                                                            
                                <core:Item key="MM"   text="MM Route Config"/>                                                                                                                                                                                 
                                <core:Item key="MMSS" text="MM Safe Stock"/>                                                                                                                                                                                   
                                <core:Item key="FI"   text="FI Limit Config"/>                                                                                                                                                                                 
                                <core:Item key="SD"   text="SD Price Config"/>                                                                                                                                                                                 
                            </items>                                                                                                                                                                                                                           
                        </Select>                                                                                                                                                                                                                              
                    </VBox>                                                                                                                                                                                                                                    
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Compare"/>                                                                                                                                                                                                                
                        <Select id="cmpEnv1" width="8rem" selectedKey="DEV">                                                                                                                                                                                   
                            <items>                                                                                                                                                                                                                            
                                <core:Item key="DEV" text="DEV"/>                                                                                                                                                                                              
                                <core:Item key="QAS" text="QAS"/>                                                                                                                                                                                              
                                <core:Item key="PRD" text="PRD"/>                                                                                                                                                                                              
                            </items>                                                                                                                                                                                                                           
                        </Select>                                                                                                                                                                                                                              
                    </VBox>                                                                                                                                                                                                                                    
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="vs"/>                                                                                                                                                                                                                     
                        <Select id="cmpEnv2" width="8rem" selectedKey="PRD">                                                                                                                                                                                   
                            <items>                                                                                                                                                                                                                            
                                <core:Item key="DEV" text="DEV"/>                                                                                                                                                                                              
                                <core:Item key="QAS" text="QAS"/>                                                                                                                                                                                              
                                <core:Item key="PRD" text="PRD"/>                                                                                                                                                                                              
                            </items>                                                                                                                                                                                                                           
                        </Select>                                                                                                                                                                                                                              
                    </VBox>                                                                                                                                                                                                                                    
                    <Button text="Compare" icon="sap-icon://compare" type="Emphasized"                                                                                                                                                                         
                            press=".onEnvCompareRun"                                                                                                                                                                                                           
                            class="sapUiTinyMarginBottom sapUiSmallMarginEnd"/>                                                                                                                                                                                
                    <VBox justifyContent="End" class="sapUiTinyMarginBottom">                                                                                                                                                                                  
                        <HBox alignItems="Center">                                                                                                                                                                                                             
                            <Label text="Diffs only" class="sapUiTinyMarginEnd"/>                                                                                                                                                                              
                            <Switch state="{cmp>/diffsOnly}" change=".onEnvCompareDiffsOnly"/>                                                                                                                                                                 
                        </HBox>                                                                                                                                                                                                                                
                    </VBox>                                                                                                                                                                                                                                    
                </HBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Summary -->                                                                                                                                                                                                                               
                <Text text="{cmp>/summary}" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                <!-- Result Table -->                                                                                                                                                                                                                          
                <Table inset="false"                                                                                                                                                                                                                           
                       noDataText="Select a config and two environments, then press Compare."                                                                                                                                                                  
                       items="{cmp>/rows}"                                                                                                                                                                                                                     
                       sticky="ColumnHeaders"                                                                                                                                                                                                                  
                       growing="true" growingThreshold="100">                                                                                                                                                                                                  
                    <columns>                                                                                                                                                                                                                                  
                        <Column width="20rem"><Text text="Key"/></Column>                                                                                                                                                                                      
                        <Column width="9rem"><Text text="Field"/></Column>                                                                                                                                                                                     
                        <Column><Text text="{cmp>/env1Label}"/></Column>                                                                                                                                                                                       
                        <Column><Text text="{cmp>/env2Label}"/></Column>                                                                                                                                                                                       
                        <Column width="11rem"><Text text="Status"/></Column>                                                                                                                                                                                   
                    </columns>                                                                                                                                                                                                                                 
                    <items>                                                                                                                                                                                                                                    
                        <ColumnListItem highlight="{cmp>statusState}">                                                                                                                                                                                         
                            <cells>                                                                                                                                                                                                                            
                                <Text text="{cmp>keyInfo}" wrapping="false"/>                                                                                                                                                                                  
                                <Text text="{cmp>field}"/>                                                                                                                                                                                                     
                                <ObjectStatus text="{cmp>val1}" state="{cmp>val1State}"/>                                                                                                                                                                      
                                <ObjectStatus text="{cmp>val2}" state="{cmp>val2State}"/>                                                                                                                                                                      
                                <ObjectStatus text="{cmp>status}" state="{cmp>statusState}"/>                                                                                                                                                                  
                            </cells>                                                                                                                                                                                                                           
                        </ColumnListItem>                                                                                                                                                                                                                      
                    </items>                                                                                                                                                                                                                                   
                </Table>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <buttons>                                                                                                                                                                                                                                              
            <Button text="Close" press=".onEnvCompareClose"/>                                                                                                                                                                                                  
        </buttons>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
    </Dialog>                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               