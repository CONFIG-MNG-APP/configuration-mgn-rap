<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
    <Dialog title="IT Admin — Environment Comparison"                                                                                                                                                                                                          
            contentWidth="76rem" contentHeight="44rem"                                                                                                                                                                                                         
            draggable="true" resizable="true">                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <VBox class="sapUiSmallMargin">                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                <!-- ── Toolbar ──────────────────────────────────────────── -->                                                                                                                                                                               
                <HBox wrap="Wrap" alignItems="End" class="sapUiTinyMarginBottom">                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                    <VBox class="sapUiSmallMarginEnd">                                                                                                                                                                                                         
                        <Label text="Config"/>                                                                                                                                                                                                                 
                        <Select id="cmpModule" width="14rem" change=".onEnvCompareRun">                                                                                                                                                                        
                            <items>                                                                                                                                                                                                                            
                                <core:Item key="MM"   text="MM Route Config"/>                                                                                                                                                                                 
                                <core:Item key="MMSS" text="MM Safe Stock"/>                                                                                                                                                                                   
                                <core:Item key="FI"   text="FI Limit Config"/>                                                                                                                                                                                 
                                <core:Item key="SD"   text="SD Price Config"/>                                                                                                                                                                                 
                            </items>                                                                                                                                                                                                                           
                        </Select>                                                                                                                                                                                                                              
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <Button text="Compare" icon="sap-icon://compare" type="Emphasized"                                                                                                                                                                         
                            press=".onEnvCompareRun"                                                                                                                                                                                                           
                            class="sapUiTinyMarginBottom sapUiSmallMarginEnd"/>                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                    <VBox justifyContent="End" class="sapUiTinyMarginBottom">                                                                                                                                                                                  
                        <HBox alignItems="Center">                                                                                                                                                                                                             
                            <Label text="Show Differences Only" class="sapUiTinyMarginEnd"/>                                                                                                                                                                   
                            <Switch state="{cmp>/diffsOnly}" change=".onEnvCompareDiffsOnly"/>                                                                                                                                                                 
                        </HBox>                                                                                                                                                                                                                                
                    </VBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    <ToolbarSpacer/>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                    <!-- Summary badges -->                                                                                                                                                                                                                    
                    <HBox alignItems="Center" class="sapUiTinyMarginBottom">                                                                                                                                                                                   
                        <ObjectStatus text="{cmp>/totalKeys} records"                                                                                                                                                                                          
                                      icon="sap-icon://database"                                                                                                                                                                                               
                                      state="None"                                                                                                                                                                                                             
                                      class="sapUiSmallMarginEnd"                                                                                                                                                                                              
                                      visible="{= ${cmp>/totalKeys} > 0}"/>                                                                                                                                                                                    
                        <ObjectStatus text="{cmp>/diffCount} differences"                                                                                                                                                                                      
                                      icon="sap-icon://warning2"                                                                                                                                                                                               
                                      state="{= ${cmp>/diffCount} > 0 ? 'Warning' : 'Success'}"                                                                                                                                                                
                                      inverted="{= ${cmp>/diffCount} > 0}"                                                                                                                                                                                     
                                      visible="{= ${cmp>/totalKeys} > 0}"/>                                                                                                                                                                                    
                    </HBox>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                </HBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- ── Legend ────────────────────────────────────────────── -->                                                                                                                                                                              
                <HBox alignItems="Center" class="sapUiTinyMarginBottom"                                                                                                                                                                                        
                      visible="{= ${cmp>/totalKeys} > 0}">                                                                                                                                                                                                     
                    <ObjectStatus text="Identical" state="Success" inverted="true"                                                                                                                                                                             
                                  class="sapUiTinyMarginEnd"/>                                                                                                                                                                                                 
                    <ObjectStatus text="Different" state="Warning" inverted="true"                                                                                                                                                                             
                                  class="sapUiTinyMarginEnd"/>                                                                                                                                                                                                 
                    <ObjectStatus text="Only in 1 ENV" state="Error" inverted="true"                                                                                                                                                                           
                                  class="sapUiTinyMarginEnd"/>                                                                                                                                                                                                 
                    <Text text="· Highlighted values differ from the others"                                                                                                                                                                                   
                          class="sapUiSmallText sapThemeNeutralText"/>                                                                                                                                                                                         
                </HBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- ── Result Table ──────────────────────────────────────── -->                                                                                                                                                                              
                <Table id="cmpTable"                                                                                                                                                                                                                           
                       inset="false"                                                                                                                                                                                                                           
                       noDataText="Select a module and click Compare."                                                                                                                                                                                         
                       items="{cmp>/rows}"                                                                                                                                                                                                                     
                       sticky="ColumnHeaders"                                                                                                                                                                                                                  
                       growing="true" growingThreshold="200">                                                                                                                                                                                                  
                    <columns>                                                                                                                                                                                                                                  
                        <Column width="18rem">                                                                                                                                                                                                                 
                            <Text text="Record Key"/>                                                                                                                                                                                                          
                        </Column>                                                                                                                                                                                                                              
                        <Column width="9rem">                                                                                                                                                                                                                  
                            <Text text="Field"/>                                                                                                                                                                                                               
                        </Column>                                                                                                                                                                                                                              
                        <Column>                                                                                                                                                                                                                               
                            <HBox alignItems="Center">                                                                                                                                                                                                         
                                <core:Icon src="sap-icon://developer-settings"                                                                                                                                                                                 
                                           color="#E9730C" size="0.8rem"                                                                                                                                                                                       
                                           class="sapUiTinyMarginEnd"/>                                                                                                                                                                                        
                                <Text text="DEV"/>                                                                                                                                                                                                             
                            </HBox>                                                                                                                                                                                                                            
                        </Column>                                                                                                                                                                                                                              
                        <Column>                                                                                                                                                                                                                               
                            <HBox alignItems="Center">                                                                                                                                                                                                         
                                <core:Icon src="sap-icon://quality-issue"                                                                                                                                                                                      
                                           color="#0070F2" size="0.8rem"                                                                                                                                                                                       
                                           class="sapUiTinyMarginEnd"/>                                                                                                                                                                                        
                                <Text text="QAS"/>                                                                                                                                                                                                             
                            </HBox>                                                                                                                                                                                                                            
                        </Column>                                                                                                                                                                                                                              
                        <Column>                                                                                                                                                                                                                               
                            <HBox alignItems="Center">                                                                                                                                                                                                         
                                <core:Icon src="sap-icon://accept"                                                                                                                                                                                             
                                           color="#107E3E" size="0.8rem"                                                                                                                                                                                       
                                           class="sapUiTinyMarginEnd"/>                                                                                                                                                                                        
                                <Text text="PRD"/>                                                                                                                                                                                                             
                            </HBox>                                                                                                                                                                                                                            
                        </Column>                                                                                                                                                                                                                              
                        <Column width="8rem" hAlign="Center">                                                                                                                                                                                                  
                            <Text text="Sync"/>                                                                                                                                                                                                                
                        </Column>                                                                                                                                                                                                                              
                    </columns>                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
                    <items>                                                                                                                                                                                                                                    
                        <ColumnListItem highlight="{cmp>_rowHighlight}">                                                                                                                                                                                       
                            <cells>                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                                <!-- Key — chỉ hiện ở row đầu của mỗi record group -->                                                                                                                                                                         
                                <VBox>                                                                                                                                                                                                                         
                                    <Text text="{cmp>keyInfo}"                                                                                                                                                                                                 
                                          wrapping="true"                                                                                                                                                                                                      
                                          visible="{cmp>_showKey}"                                                                                                                                                                                             
                                          class="sapUiBoldText"/>                                                                                                                                                                                              
                                </VBox>                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                                <!-- Field name -->                                                                                                                                                                                                            
                                <Text text="{cmp>field}"                                                                                                                                                                                                       
                                      class="sapUiSmallText sapThemeNeutralText"/>                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                                <!-- DEV value -->                                                                                                                                                                                                             
                                <ObjectStatus                                                                                                                                                                                                                  
                                    text="{= ${cmp>devVal} || '—'}"                                                                                                                                                                                            
                                    state="{cmp>devState}"                                                                                                                                                                                                     
                                    inverted="{= ${cmp>devState} !== 'None'}"/>                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                                <!-- QAS value -->                                                                                                                                                                                                             
                                <ObjectStatus                                                                                                                                                                                                                  
                                    text="{= ${cmp>qasVal} || '—'}"                                                                                                                                                                                            
                                    state="{cmp>qasState}"                                                                                                                                                                                                     
                                    inverted="{= ${cmp>qasState} !== 'None'}"/>                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                                <!-- PRD value -->                                                                                                                                                                                                             
                                <ObjectStatus                                                                                                                                                                                                                  
                                    text="{= ${cmp>prdVal} || '—'}"                                                                                                                                                                                            
                                    state="{cmp>prdState}"                                                                                                                                                                                                     
                                    inverted="{= ${cmp>prdState} !== 'None'}"/>                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                                <!-- Sync status — chỉ hiện ở row đầu -->                                                                                                                                                                                      
                                <ObjectStatus                                                                                                                                                                                                                  
                                    text="{cmp>_syncText}"                                                                                                                                                                                                     
                                    state="{cmp>_syncState}"                                                                                                                                                                                                   
                                    inverted="{= ${cmp>_syncState} !== 'None'}"                                                                                                                                                                                
                                    visible="{cmp>_showKey}"/>                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
                            </cells>                                                                                                                                                                                                                           
                        </ColumnListItem>                                                                                                                                                                                                                      
                    </items>                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
                </Table>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <buttons>                                                                                                                                                                                                                                              
            <Button text="Close" press=".onEnvCompareClose"/>                                                                                                                                                                                                  
        </buttons>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
    </Dialog>                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               